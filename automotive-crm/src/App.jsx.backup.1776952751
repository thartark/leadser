    <div className="flex justify-between items-center"><h2 className="text-xl font-semibold">Active Campaigns</h2><button className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ New Campaign</button></div>
    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        { name: "Summer Clearance", type: "Email", sent: 2500, openRate: 42, revenue: 125000 },
        { name: "Labor Day Event", type: "SMS", sent: 1800, openRate: 78, revenue: 189000 },
        { name: "New Model Launch", type: "Social", sent: 3200, openRate: 35, revenue: 89000 },
        { name: "Service Special", type: "Email", sent: 4200, openRate: 28, revenue: 45000 },
        { name: "Trade-in Bonus", type: "Email", sent: 1500, openRate: 55, revenue: 98000 },
