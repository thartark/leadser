      <div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-emerald-600">43</p><p className="text-sm text-slate-500">Active Opps</p></div>
      <div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-amber-600">67%</p><p className="text-sm text-slate-500">Win Rate</p></div>
    </div>
    <div className="bg-white dark:bg-slate-800 rounded-xl p-6 border"><p className="text-center text-slate-500">Opportunity details will appear here</p></div>
  </div>
);

