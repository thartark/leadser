      ].map((campaign, idx) => (
        <div key={idx} className="bg-white dark:bg-slate-800 rounded-xl p-5 border hover:shadow-md transition-all"><div className="flex justify-between items-start mb-3"><div><h3 className="font-semibold">{campaign.name}</h3><p className="text-xs text-slate-500">{campaign.type} Campaign</p></div><StatusBadge status="active" /></div><div className="grid grid-cols-3 gap-2 text-center mb-3"><div><p className="text-lg font-bold">{campaign.sent.toLocaleString()}</p><p className="text-xs text-slate-500">Sent</p></div><div><p className="text-lg font-bold">{campaign.openRate}%</p><p className="text-xs text-slate-500">Open</p></div><div><p className="text-lg font-bold">${(campaign.revenue/1000).toFixed(0)}K</p><p className="text-xs text-slate-500">Revenue</p></div></div><button className="w-full py-2 text-indigo-600 text-sm font-medium hover:bg-indigo-50 rounded-lg">View Details</button></div>
      ))}
