// ==================== DASHBOARD PAGE ====================
const Dashboard = ({ onToast, onSelectLead }) => (
  <div className="space-y-6">
    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      <KpiCard title="New Leads Today" value="23" change="+12% vs yesterday" icon={Users} color="bg-indigo-500" />
      <KpiCard title="Appointments Set" value="18" change="67% show rate" icon={Calendar} color="bg-emerald-500" />
      <KpiCard title="Deals Closed MTD" value="47" change="$324,500 gross" icon={Target} color="bg-amber-500" />
      <KpiCard title="Avg Response Time" value="4.2 min" change="-18% vs last week" icon={Clock} color="bg-rose-500" />
    </div>
    
    <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border border-slate-200">
        <h3 className="font-semibold mb-4">Lead Volume (Last 30 Days)</h3>
        <ResponsiveContainer width="100%" height={300}>
          <AreaChart data={leadVolumeData}>
            <CartesianGrid strokeDasharray="3 3" />
            <XAxis dataKey="day" />
            <YAxis />
            <Tooltip />
            <Area type="monotone" dataKey="leads" stroke="#4F46E5" fill="#4F46E5" fillOpacity={0.1} />
            <Area type="monotone" dataKey="conversions" stroke="#10B981" fill="#10B981" fillOpacity={0.1} />
          </AreaChart>
        </ResponsiveContainer>
      </div>
      
      <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border border-slate-200">
        <h3 className="font-semibold mb-4">Lead Sources</h3>
        <ResponsiveContainer width="100%" height={300}>
          <RePieChart>
            <Pie data={leadSourcesData} cx="50%" cy="50%" innerRadius={60} outerRadius={100} paddingAngle={5} dataKey="value" label={({ name, percent }) => `${name} ${(percent * 100).toFixed(0)}%`}>
              {leadSourcesData.map((entry, idx) => <Cell key={idx} fill={entry.color} />)}
            </Pie>
            <Tooltip />
          </RePieChart>
        </ResponsiveContainer>
      </div>
    </div>
    
    <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border border-slate-200">
        <h3 className="font-semibold mb-4">Salesperson Performance</h3>
        <ResponsiveContainer width="100%" height={300}>
          <ReBarChart data={salespersonPerformance}>
            <CartesianGrid strokeDasharray="3 3" />
            <XAxis dataKey="name" />
            <YAxis yAxisId="left" />
            <YAxis yAxisId="right" orientation="right" />
            <Tooltip />
            <Legend />
            <Bar yAxisId="left" dataKey="units" fill="#4F46E5" name="Units Sold" />
            <Bar yAxisId="right" dataKey="gross" fill="#10B981" name="Gross ($K)" />
          </ReBarChart>
        </ResponsiveContainer>
      </div>
      
      <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border border-slate-200">
        <h3 className="font-semibold mb-4 flex items-center justify-between">
          <span>Hot Leads Feed</span>
          <span className="text-xs text-rose-500 animate-pulse">● Live</span>
        </h3>
        <div className="space-y-3 max-h-[300px] overflow-y-auto">
          {hotLeads.map(lead => (
            <div key={lead.id} className="flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-700/50 rounded-lg cursor-pointer hover:bg-slate-100 transition-colors" onClick={() => onSelectLead(lead)}>
              <div className="flex-1">
                <div className="flex items-center gap-2"><p className="font-medium text-sm">{lead.name}</p><StatusBadge status={lead.status} /></div>
                <p className="text-xs text-slate-500 mt-1">{lead.vehicle}</p>
                <p className="text-xs text-slate-400 mt-1">{lead.lastActivity}</p>
              </div>
              <div className="flex gap-2">
                <button onClick={(e) => { e.stopPropagation(); onToast(`Calling ${lead.name}...`, "info"); }} className="p-2 bg-emerald-100 dark:bg-emerald-900/30 rounded-lg"><Phone size={14} className="text-emerald-600" /></button>
                <button onClick={(e) => { e.stopPropagation(); onToast(`Texting ${lead.name}...`, "info"); }} className="p-2 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg"><MessageSquare size={14} className="text-indigo-600" /></button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
);

// ==================== LEADS PAGE ====================
const LeadsPage = ({ onToast, onSelectLead }) => {
  const [search, setSearch] = useState("");
  const [filterStatus, setFilterStatus] = useState("all");
  const [filterSource, setFilterSource] = useState("all");
  const [filterRep, setFilterRep] = useState("all");
  
  const filteredLeads = leadsData.filter(lead => {
    if (filterStatus !== "all" && lead.status !== filterStatus) return false;
    if (filterSource !== "all" && lead.source !== filterSource) return false;
    if (filterRep !== "all" && lead.rep !== filterRep) return false;
    if (search && !lead.name.toLowerCase().includes(search.toLowerCase()) && !lead.vehicle.toLowerCase().includes(search.toLowerCase())) return false;
    return true;
  });
  
  const uniqueSources = [...new Set(leadsData.map(l => l.source))];
  const uniqueReps = [...new Set(leadsData.map(l => l.rep))];
  
  return (
    <div className="space-y-5">
      <div className="flex flex-wrap gap-3 items-center justify-between">
        <div className="flex flex-wrap gap-2">
          <select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className="px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-sm">
            <option value="all">All Status</option><option value="Hot">Hot</option><option value="Warm">Warm</option><option value="Cold">Cold</option>
          </select>
          <select value={filterSource} onChange={(e) => setFilterSource(e.target.value)} className="px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-sm">
            <option value="all">All Sources</option>{uniqueSources.map(s => <option key={s} value={s}>{s}</option>)}
          </select>
          <select value={filterRep} onChange={(e) => setFilterRep(e.target.value)} className="px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-sm">
            <option value="all">All Reps</option>{uniqueReps.map(r => <option key={r} value={r}>{r}</option>)}
          </select>
          <input type="text" placeholder="Search leads..." value={search} onChange={(e) => setSearch(e.target.value)} className="px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-sm w-64" />
        </div>
        <button className="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm flex items-center gap-2"><Filter size={16} /> Filter</button>
      </div>
      
      <div className="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden">
        <div className="overflow-x-auto">
          <table className="w-full">
            <thead className="bg-slate-50 dark:bg-slate-700/50">
              <tr className="text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
                <th className="px-4 py-3">Score</th><th className="px-4 py-3">Customer</th><th className="px-4 py-3">Contact</th><th className="px-4 py-3">Vehicle</th><th className="px-4 py-3">Source</th><th className="px-4 py-3">Status</th><th className="px-4 py-3">Rep</th><th className="px-4 py-3">Last Activity</th><th className="px-4 py-3">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-slate-100 dark:divide-slate-700">
              {filteredLeads.map(lead => (
                <tr key={lead.id} className="hover:bg-slate-50 dark:hover:bg-slate-700/30 cursor-pointer transition-colors group" onClick={() => onSelectLead(lead)}>
                  <td className="px-4 py-3">
                    <span className={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
                      lead.score >= 80 ? 'bg-rose-100 text-rose-700' : 
                      lead.score >= 60 ? 'bg-amber-100 text-amber-700' : 
                      'bg-slate-100 text-slate-700'
                    }`}>{lead.score}</span>
                  </td>
                  <td className="px-4 py-3 font-medium text-sm">{lead.name}</td>
                  <td className="px-4 py-3">
                    <div className="flex gap-1">
                      <a href={`tel:${lead.phone}`} onClick={(e) => e.stopPropagation()} className="p-1 hover:bg-slate-100 rounded"><Phone size={14} className="text-slate-400" /></a>
                      <a href={`mailto:${lead.email}`} onClick={(e) => e.stopPropagation()} className="p-1 hover:bg-slate-100 rounded"><Mail size={14} className="text-slate-400" /></a>
                    </div>
                  </td>
                  <td className="px-4 py-3 text-sm">{lead.vehicle.split(' ').slice(0,3).join(' ')}</td>
                  <td className="px-4 py-3 text-sm">{lead.source}</td>
                  <td className="px-4 py-3"><StatusBadge status={lead.status} /></td>
                  <td className="px-4 py-3 text-sm">{lead.rep.split(' ')[0]}</td>
                  <td className="px-4 py-3 text-sm text-slate-500">{lead.lastActivity}</td>
                  <td className="px-4 py-3">
                    <div className="flex gap-1">
                      <button onClick={(e) => { e.stopPropagation(); onToast(`Logging call for ${lead.name}`, "success"); }} className="p-1 hover:bg-slate-100 rounded"><PhoneCall size={14} /></button>
                      <button onClick={(e) => { e.stopPropagation(); onToast(`Sending text to ${lead.name}`, "success"); }} className="p-1 hover:bg-slate-100 rounded"><MessageSquare size={14} /></button>
                      <button onClick={(e) => { e.stopPropagation(); onToast(`Setting appointment for ${lead.name}`, "success"); }} className="p-1 hover:bg-slate-100 rounded"><Calendar size={14} /></button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
};

// ==================== PIPELINE KANBAN PAGE ====================
const PipelinePage = ({ onToast }) => {
  const [viewMode, setViewMode] = useState("kanban");
  const stages = ["New Lead", "Contacted", "Appointment Set", "Appointment Showed", "Demo/Test Drive", "Negotiating", "Sold", "Lost"];
  
  const getLeadsByStage = (stage) => {
    if (stage === "New Lead") return leadsData.filter(l => l.daysInStage <= 2);
    if (stage === "Contacted") return leadsData.filter(l => l.daysInStage > 2 && l.daysInStage <= 5);
    if (stage === "Appointment Set") return leadsData.filter(l => l.score > 80);
    if (stage === "Appointment Showed") return leadsData.filter(l => l.score > 70 && l.score <= 80);
    if (stage === "Demo/Test Drive") return leadsData.filter(l => l.websiteVisits > 3);
    if (stage === "Negotiating") return leadsData.filter(l => l.tradeInSubmitted);
    if (stage === "Sold") return leadsData.filter(l => l.id === 7);
    if (stage === "Lost") return leadsData.filter(l => l.id === 3);
    return [];
  };
  
  if (viewMode === "list") {
    return (
      <div className="space-y-4">
        <div className="flex justify-between items-center"><h2 className="text-xl font-semibold">Pipeline List View</h2><button onClick={() => setViewMode("kanban")} className="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm">Switch to Kanban</button></div>
        {stages.map(stage => {
          const leads = getLeadsByStage(stage);
          return leads.length > 0 && (
            <div key={stage} className="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 overflow-hidden">
              <div className="bg-slate-50 dark:bg-slate-700/50 px-4 py-2 font-medium text-sm">{stage} ({leads.length})</div>
              <div className="divide-y">{leads.map(lead => (<div key={lead.id} className="px-4 py-2 text-sm flex justify-between items-center"><span>{lead.name} - {lead.vehicle.split(' ').slice(0,2).join(' ')}</span><span className="text-slate-500 text-xs">{lead.daysInStage} days</span></div>))}</div>
            </div>
          );
        })}
      </div>
    );
  }
  
  return (
    <div className="space-y-4">
      <div className="flex justify-between items-center"><h2 className="text-xl font-semibold">Sales Pipeline</h2><button onClick={() => setViewMode("list")} className="px-4 py-2 bg-slate-100 dark:bg-slate-700 rounded-lg text-sm">Switch to List View</button></div>
      <div className="flex gap-4 overflow-x-auto pb-4">
        {stages.map(stage => {
          const leads = getLeadsByStage(stage);
          return (
            <div key={stage} className="min-w-[280px] bg-slate-50 dark:bg-slate-800/50 rounded-xl p-3">
              <div className="flex justify-between items-center mb-3 px-2"><h3 className="font-medium text-sm">{stage}</h3><span className="text-xs text-slate-500">{leads.length}</span></div>
              <div className="space-y-2">
                {leads.map(lead => (
                  <div key={lead.id} className="bg-white dark:bg-slate-800 rounded-lg p-3 shadow-sm border border-slate-200 dark:border-slate-700 cursor-move hover:shadow-md transition-shadow">
                    <div className="flex justify-between items-start"><p className="font-medium text-sm">{lead.name}</p><div className="w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center text-xs font-medium">{lead.rep.split(' ').map(n => n[0]).join('')}</div></div>
                    <p className="text-xs text-slate-500 mt-1">{lead.vehicle.split(' ').slice(0,3).join(' ')}</p>
                    <div className="flex justify-between items-center mt-2"><span className="text-xs text-slate-400">{lead.daysInStage} days</span><button onClick={() => onToast(`Contacting ${lead.name}`, "info")} className="text-xs text-indigo-500">Contact</button></div>
                    <div className={`mt-2 w-1 h-1 rounded-full ${lead.score >= 80 ? 'bg-rose-500' : lead.score >= 60 ? 'bg-amber-500' : 'bg-slate-400'} animate-pulse`}></div>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
};

// ==================== INVENTORY PAGE ====================
const InventoryPage = ({ onToast }) => {
  const [filterType, setFilterType] = useState("all");
  const [selectedVehicle, setSelectedVehicle] = useState(null);
  
  const filteredInventory = inventoryData.filter(v => filterType === "all" || v.type === filterType);
  
  const reconSteps = ["Arrived", "Inspected", "Recon", "Detail", "Photos", "Front Line Ready"];
  
  return (
    <div className="space-y-5">
      <div className="flex flex-wrap gap-3 items-center justify-between">
        <div className="flex gap-2">
          <div className="flex bg-slate-100 dark:bg-slate-700 rounded-lg p-1">
            {["all", "New", "Used"].map(type => (
              <button key={type} onClick={() => setFilterType(type.toLowerCase())} className={`px-4 py-1.5 text-sm rounded-md transition-colors ${filterType === type.toLowerCase() ? 'bg-white dark:bg-slate-600 shadow-sm' : ''}`}>{type === "all" ? "All" : type}</button>
            ))}
          </div>
          <select className="px-3 py-2 border rounded-lg text-sm bg-white dark:bg-slate-800"><option>All Makes</option><option>Ford</option><option>Tesla</option><option>BMW</option><option>Mercedes</option></select>
          <input type="range" min="0" max="100" className="w-32" />
        </div>
        <button className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ Add Vehicle</button>
      </div>
      
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {filteredInventory.map(vehicle => (
          <div key={vehicle.id} className="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-md transition-all cursor-pointer group" onClick={() => setSelectedVehicle(vehicle)}>
            <div className="h-32 bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-lg font-bold relative group-hover:scale-105 transition-transform">
              {vehicle.make} {vehicle.model}
              <div className={`absolute top-2 right-2 w-2 h-2 rounded-full ${vehicle.status === "Available" ? "bg-emerald-400 animate-pulse" : "bg-slate-400"}`}></div>
            </div>
            <div className="p-4">
              <div className="flex justify-between items-start mb-2">
                <div><h3 className="font-semibold">{vehicle.year} {vehicle.make} {vehicle.model} {vehicle.trim}</h3><p className="text-xs text-slate-500">Stock #{vehicle.stock} · VIN ...{vehicle.vin.slice(-6)}</p></div>
                <StatusBadge status={vehicle.status} />
              </div>
              <div className="flex justify-between items-center mb-2">
                <div><p className="text-xl font-bold text-indigo-600">${vehicle.price.toLocaleString()}</p><p className="text-xs text-slate-500 line-through">Cost: ${vehicle.cost.toLocaleString()}</p></div>
                <div className={`text-sm font-medium ${vehicle.daysOnLot < 30 ? 'text-emerald-600' : vehicle.daysOnLot < 60 ? 'text-amber-600' : 'text-rose-600'}`}>{vehicle.daysOnLot} days</div>
              </div>
              <div className="flex gap-2 mt-3">
                <button onClick={(e) => { e.stopPropagation(); onToast(`Matching leads for ${vehicle.model}`, "success"); }} className="flex-1 py-2 bg-indigo-50 text-indigo-600 rounded-lg text-sm font-medium hover:bg-indigo-100">Match to Lead</button>
                <button className="flex-1 py-2 bg-slate-100 dark:bg-slate-700 rounded-lg text-sm">Details</button>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      {selectedVehicle && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50" onClick={() => setSelectedVehicle(null)}>
          <div className="bg-white dark:bg-slate-800 rounded-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto" onClick={(e) => e.stopPropagation()}>
            <div className="sticky top-0 bg-white dark:bg-slate-800 p-5 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
              <h2 className="text-xl font-semibold">{selectedVehicle.year} {selectedVehicle.make} {selectedVehicle.model}</h2>
              <button onClick={() => setSelectedVehicle(null)} className="p-1 hover:bg-slate-100 rounded-lg"><X size={20} /></button>
            </div>
            <div className="p-5 space-y-5">
              <div className="h-40 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-xl flex items-center justify-center text-white text-2xl font-bold">{selectedVehicle.make} {selectedVehicle.model}</div>
              <div className="grid grid-cols-2 gap-4">
                <div><p className="text-sm text-slate-500">Price</p><p className="text-2xl font-bold text-indigo-600">${selectedVehicle.price.toLocaleString()}</p></div>
                <div><p className="text-sm text-slate-500">Market Comparison</p><p className="text-emerald-600 text-sm font-medium">$1,200 below market avg</p></div>
                <div><p className="text-sm text-slate-500">Engine</p><p className="font-medium">{selectedVehicle.engine}</p></div>
                <div><p className="text-sm text-slate-500">MPG</p><p className="font-medium">{selectedVehicle.mpg}</p></div>
                <div><p className="text-sm text-slate-500">Color</p><p className="font-medium">{selectedVehicle.color}</p></div>
                <div><p className="text-sm text-slate-500">VIN</p><p className="font-mono text-sm">{selectedVehicle.vin}</p></div>
              </div>
              
              <div><p className="text-sm text-slate-500 mb-2">Recon Status</p><div className="flex flex-wrap gap-2">{reconSteps.map((step, idx) => (<div key={step} className={`px-2 py-1 rounded-lg text-xs ${selectedVehicle.recon[step.toLowerCase().replace(/ /g, '')] ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'}`}>{step} {selectedVehicle.recon[step.toLowerCase().replace(/ /g, '')] && '✓'}</div>))}</div></div>
              
              <div><p className="text-sm text-slate-500 mb-2">Features</p><div className="flex flex-wrap gap-2">{selectedVehicle.features.map((f, i) => (<span key={i} className="px-2 py-1 bg-slate-100 dark:bg-slate-700 rounded-lg text-xs">{f}</span>))}</div></div>
              
              <div className="flex gap-3"><button className="flex-1 bg-indigo-600 text-white py-2 rounded-lg font-medium">Contact Leads</button><button className="flex-1 bg-slate-100 py-2 rounded-lg">Schedule Test Drive</button></div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

// ==================== SERVICE DRIVE PAGE ====================
const ServiceDrivePage = ({ onToast }) => {
  const [appointments, setAppointments] = useState(serviceAppointments);
  const [filterStatus, setFilterStatus] = useState("all");
  
  const filteredAppointments = appointments.filter(apt => filterStatus === "all" || apt.status === filterStatus);
  
  const updateStatus = (id, newStatus) => {
    setAppointments(appointments.map(apt => apt.id === id ? { ...apt, status: newStatus } : apt));
    onToast(`Status updated to ${newStatus}`, "success");
  };
  
  const timeSlots = ["7:00 AM", "8:00 AM", "9:00 AM", "10:00 AM", "11:00 AM", "12:00 PM", "1:00 PM", "2:00 PM", "3:00 PM", "4:00 PM", "5:00 PM", "6:00 PM"];
  const stats = { total: appointments.length, avgCycleTime: "2.4h", csiScore: "4.8", loanersOut: 3 };
  
  return (
    <div className="flex gap-6">
      <div className="flex-1">
        <div className="mb-4 flex gap-2">
          {["all", "Scheduled", "Waiting", "In Progress", "With Tech", "Ready", "Delivered"].map(status => (
            <button key={status} onClick={() => setFilterStatus(status.toLowerCase())} className={`px-3 py-1.5 text-sm rounded-lg transition-colors ${filterStatus === status.toLowerCase() ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-100 dark:bg-slate-700'}`}>{status === "all" ? "All" : status}</button>
          ))}
        </div>
        <div className="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div className="divide-y">
            {filteredAppointments.map(apt => (
              <div key={apt.id} className="flex items-center justify-between p-4 hover:bg-slate-50 transition-colors">
                <div className="flex items-center gap-4 min-w-[200px]"><div className="w-20"><p className="font-bold text-indigo-600">{apt.time}</p></div><div><p className="font-medium">{apt.customer}</p><p className="text-sm text-slate-500">{apt.vehicle}</p></div></div>
                <div className="flex-1 px-4"><p className="text-sm">{apt.service}</p><p className="text-xs text-slate-500">Advisor: {apt.advisor}</p></div>
                <div className="flex items-center gap-3">
                  <StatusBadge status={apt.status} />
                  <select value={apt.status} onChange={(e) => updateStatus(apt.id, e.target.value)} className="px-2 py-1 text-sm border rounded-lg">
                    <option>Scheduled</option><option>Waiting</option><option>In Progress</option><option>With Tech</option><option>Ready</option><option>Delivered</option>
                  </select>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div className="w-64 space-y-3">
        <div className="bg-white dark:bg-slate-800 rounded-xl p-4 border border-slate-200"><p className="text-2xl font-bold">{stats.total}</p><p className="text-sm text-slate-500">Total ROs Today</p></div>
        <div className="bg-white dark:bg-slate-800 rounded-xl p-4 border border-slate-200"><p className="text-2xl font-bold">{stats.avgCycleTime}</p><p className="text-sm text-slate-500">Avg Cycle Time</p></div>
        <div className="bg-white dark:bg-slate-800 rounded-xl p-4 border border-slate-200"><p className="text-2xl font-bold">{stats.csiScore}</p><p className="text-sm text-slate-500">CSI Score</p></div>
        <div className="bg-white dark:bg-slate-800 rounded-xl p-4 border border-slate-200"><p className="text-2xl font-bold">{stats.loanersOut}</p><p className="text-sm text-slate-500">Loaner Vehicles</p></div>
      </div>
    </div>
  );
};

// ==================== ANALYTICS PAGE ====================
const AnalyticsPage = ({ onToast }) => {
  const [dateRange, setDateRange] = useState("mtd");
  const ranges = [{ id: "mtd", label: "MTD" }, { id: "lastMonth", label: "Last Month" }, { id: "last90", label: "Last 90 Days" }, { id: "custom", label: "Custom" }];
  
  const totalUnits = salespeople.reduce((sum, r) => sum + r.units, 0);
  const totalGross = salespeople.reduce((sum, r) => sum + r.gross, 0);
  
  return (
    <div className="space-y-6">
      <div className="flex gap-2"><div className="flex bg-slate-100 rounded-lg p-1">{ranges.map(range => (<button key={range.id} onClick={() => setDateRange(range.id)} className={`px-4 py-1.5 text-sm rounded-md ${dateRange === range.id ? 'bg-white shadow-sm' : ''}`}>{range.label}</button>))}</div></div>
      
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Salesperson Leaderboard</h3><div className="space-y-3">{[...salespeople].sort((a,b) => b.units - a.units).map((rep, idx) => (<div key={rep.id} className="flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg"><div className="flex items-center gap-3"><div className={`w-8 h-8 rounded-full ${rep.color} flex items-center justify-center text-white text-xs font-bold`}>{rep.initials}</div><div><p className="font-medium text-sm">{rep.name}</p><p className="text-xs text-slate-500">{rep.units} units · ${(rep.gross/1000).toFixed(0)}K gross</p></div></div><div className="text-right"><p className="font-medium text-emerald-600">{rep.closeRate}%</p><p className="text-xs text-slate-500">close rate</p></div></div>))}</div></div>
        
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Lead Source ROI</h3><ResponsiveContainer width="100%" height={300}><ReBarChart data={leadSourcesData}><CartesianGrid strokeDasharray="3 3" /><XAxis dataKey="name" /><YAxis /><Tooltip /><Legend /><Bar dataKey="costPerLead" fill="#4F46E5" name="Cost/Lead ($)" /><Bar dataKey="costPerSale" fill="#10B981" name="Cost/Sale ($)" /></ReBarChart></ResponsiveContainer></div>
      </div>
      
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Lost Deal Reasons</h3><ResponsiveContainer width="100%" height={250}><RePieChart><Pie data={lostDealReasons} cx="50%" cy="50%" innerRadius={50} outerRadius={80} dataKey="value" label={({ name, percent }) => `${name} ${(percent * 100).toFixed(0)}%`}>{lostDealReasons.map((entry, idx) => <Cell key={idx} fill={entry.color} />)}</Pie><Tooltip /></RePieChart></ResponsiveContainer></div>
        
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Response Time Heatmap</h3><div className="overflow-x-auto"><table className="w-full text-sm"><thead><tr><th className="p-2"></th><th className="p-2">Mon</th><th className="p-2">Tue</th><th className="p-2">Wed</th><th className="p-2">Thu</th><th className="p-2">Fri</th></tr></thead><tbody>{responseTimeHeatmap.map(row => (<tr key={row.hour}><td className="p-2 font-medium">{row.hour}</td>{["Mon","Tue","Wed","Thu","Fri"].map(day => { const val = row[day]; return <td key={day} className="p-2"><div className={`px-2 py-1 rounded text-center text-white ${val > 5 ? 'bg-rose-500' : val > 4 ? 'bg-amber-500' : 'bg-emerald-500'}`}>{val}m</div></td>; })}</tr>))}</tbody></table></div></div>
      </div>
      
      <div className="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl p-6 text-white"><p className="text-sm font-medium mb-2">📊 Forecast</p><p className="text-lg">On pace for {Math.round(totalUnits * 1.15)} units this month. Need {Math.max(0, 87 - totalUnits)} more to hit goal.</p><button className="mt-3 px-4 py-2 bg-white/20 rounded-lg text-sm font-medium hover:bg-white/30">View Recommendations</button></div>
    </div>
  );
};

