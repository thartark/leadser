  { id: 3, title: "Follow up with Rachel Cohen", priority: "High", due: "Tomorrow, 10:00 AM", type: "call", completed: false, assignee: "David Kim" },
  { id: 4, title: "Prepare paperwork for Marcus Webb", priority: "Low", due: "Tomorrow, 3:00 PM", type: "task", completed: true, assignee: "Jessica Williams" },
  { id: 5, title: "Schedule test drive for Kevin Zhang", priority: "Medium", due: "Wednesday, 11:00 AM", type: "calendar", completed: false, assignee: "Sarah Chen" },
];
const dealerLocations = [
  { name: "Downtown Showroom", address: "123 Main St", sales: 156, service: 89, rating: 4.8, hours: "9am-8pm", phone: "(555) 111-2222" },
  { name: "Northside Auto Mall", address: "456 North Blvd", sales: 203, service: 112, rating: 4.9, hours: "9am-9pm", phone: "(555) 222-3333" },
  { name: "Eastside Service Center", address: "789 East Rd", sales: 98, service: 156, rating: 4.7, hours: "8am-6pm", phone: "(555) 333-4444" },
];
const financialData = {
  monthlyRevenue: [124000, 156000, 189000, 234000, 278000, 312000, 345000, 389000, 423000, 456000, 489000, 523000],
  expenses: [89000, 92000, 95000, 98000, 101000, 104000, 107000, 110000, 113000, 116000, 119000, 122000],
  profit: [35000, 64000, 94000, 136000, 177000, 208000, 238000, 279000, 310000, 340000, 370000, 401000],
};
const inventoryTurnover = [{ month: "Jan", turnover: 8.5, daysOnLot: 32 }, { month: "Feb", turnover: 9.2, daysOnLot: 28 }, { month: "Mar", turnover: 8.8, daysOnLot: 30 }, { month: "Apr", turnover: 10.1, daysOnLot: 25 }, { month: "May", turnover: 9.5, daysOnLot: 27 }, { month: "Jun", turnover: 11.2, daysOnLot: 22 }];

// ==================== COMPONENTS ====================
const StatusBadge = ({ status }) => {
  const config = { Hot: "bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400", Warm: "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400", Cold: "bg-slate-100 text-slate-700", Available: "bg-emerald-100 text-emerald-700", Sold: "bg-slate-100", Pending: "bg-indigo-100 text-indigo-700", "In Progress": "bg-indigo-100 text-indigo-700", Waiting: "bg-amber-100 text-amber-700", Scheduled: "bg-slate-100", Completed: "bg-emerald-100 text-emerald-700", active: "bg-emerald-100 text-emerald-700", inactive: "bg-slate-100", High: "bg-rose-100 text-rose-700", Medium: "bg-amber-100 text-amber-700", Low: "bg-slate-100" };
  return <span className={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${config[status] || "bg-slate-100"}`}>{status}</span>;
};

const KpiCard = ({ title, value, change, icon: Icon, color, subtitle }) => (
  <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border border-slate-200 dark:border-slate-700 hover:shadow-md transition-all group cursor-pointer">
    <div className="flex justify-between items-start">
      <div><p className="text-sm text-slate-500">{title}</p><p className="text-2xl font-bold mt-1">{value}</p>{change && <div className={`flex items-center gap-1 mt-2 text-xs ${change.startsWith('+') ? 'text-emerald-600' : 'text-rose-600'}`}>{change.startsWith('+') ? <TrendingUp size={12} /> : <TrendingDown size={12} />}<span>{change}</span></div>}{subtitle && <p className="text-xs text-slate-400 mt-1">{subtitle}</p>}</div>
      <div className={`p-3 rounded-lg ${color} group-hover:scale-110 transition-transform`}><Icon size={20} className="text-white" /></div>
    </div>
  </div>
);

const Toast = ({ message, type, onClose }) => {
  useEffect(() => { const timer = setTimeout(onClose, 4000); return () => clearTimeout(timer); }, [onClose]);
  const icons = { success: <Check size={16} />, error: <AlertCircle size={16} />, info: <Info size={16} /> };
  const colors = { success: "bg-emerald-500", error: "bg-rose-500", info: "bg-indigo-500" };
  return <div className={`fixed bottom-4 right-4 z-50 flex items-center gap-2 px-4 py-3 rounded-lg shadow-lg text-white ${colors[type]} animate-fade-in`}>{icons[type]}<span className="text-sm">{message}</span></div>;
};

const QuickAddFab = ({ onAction }) => {
  const [open, setOpen] = useState(false);
  const actions = [
    { icon: <UserPlus size={16} />, label: "Add Lead", color: "bg-indigo-500", action: "lead" },
    { icon: <PhoneCall size={16} />, label: "Log Call", color: "bg-emerald-500", action: "call" },
    { icon: <Calendar size={16} />, label: "Set Appointment", color: "bg-amber-500", action: "appointment" },
    { icon: <FileText size={16} />, label: "Add Note", color: "bg-purple-500", action: "note" },
    { icon: <Mail size={16} />, label: "Send Email", color: "bg-cyan-500", action: "email" },
    { icon: <MessageCircle size={16} />, label: "Send SMS", color: "bg-rose-500", action: "sms" },
    { icon: <Car size={16} />, label: "Add Vehicle", color: "bg-orange-500", action: "vehicle" },
  ];
  return (<div className="fixed bottom-6 right-6 z-40">{open && (<div className="absolute bottom-16 right-0 space-y-2 animate-fade-in">{actions.map((action, idx) => (<button key={idx} onClick={() => { onAction(action.action); setOpen(false); }} className={`flex items-center gap-2 px-4 py-2 ${action.color} text-white rounded-full shadow-lg hover:opacity-90 transition-all text-sm whitespace-nowrap`}>{action.icon}{action.label}</button>))}</div>)}<button onClick={() => setOpen(!open)} className={`w-14 h-14 rounded-full shadow-lg flex items-center justify-center transition-all ${open ? 'bg-slate-600 rotate-45' : 'bg-indigo-500 hover:bg-indigo-600'} text-white`}><Plus size={24} /></button></div>);
};

const GlobalSearch = ({ onSelect }) => {
  const [query, setQuery] = useState("");
  const [results, setResults] = useState([]);
  const [showResults, setShowResults] = useState(false);
  const searchRef = useRef(null);
  useEffect(() => { const handleClickOutside = (e) => { if (searchRef.current && !searchRef.current.contains(e.target)) setShowResults(false); }; document.addEventListener('mousedown', handleClickOutside); return () => document.removeEventListener('mousedown', handleClickOutside); }, []);
  useEffect(() => { if (query.length > 1) { const matchedLeads = leadsData.filter(l => l.name.toLowerCase().includes(query.toLowerCase()) || l.vehicle.toLowerCase().includes(query.toLowerCase()) || l.email.toLowerCase().includes(query.toLowerCase()) || l.company.toLowerCase().includes(query.toLowerCase())).slice(0, 5); const matchedVehicles = inventoryData.filter(v => `${v.year} ${v.make} ${v.model}`.toLowerCase().includes(query.toLowerCase()) || v.vin.includes(query)).slice(0, 5); const matchedTasks = upcomingTasks.filter(t => t.title.toLowerCase().includes(query.toLowerCase())).slice(0, 3); setResults([...matchedLeads.map(l => ({ type: "lead", ...l })), ...matchedVehicles.map(v => ({ type: "vehicle", ...v })), ...matchedTasks.map(t => ({ type: "task", ...t }))]); setShowResults(true); } else { setResults([]); setShowResults(false); } }, [query]);
  const getIcon = (type) => { switch(type) { case "lead": return <Users size={14} className="text-indigo-500" />; case "vehicle": return <Car size={14} className="text-emerald-500" />; case "task": return <CheckCircle size={14} className="text-amber-500" />; default: return <Search size={14} className="text-slate-400" />; } };
  return (<div className="relative" ref={searchRef}><Search size={18} className="absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" /><input type="text" placeholder="Search customers, vehicles, tasks, emails..." value={query} onChange={(e) => setQuery(e.target.value)} className="pl-9 pr-4 py-1.5 text-sm border rounded-lg bg-slate-50 dark:bg-slate-800 w-96 focus:outline-none focus:ring-2 focus:ring-indigo-500" />{showResults && results.length > 0 && (<div className="absolute top-full left-0 right-0 mt-2 bg-white dark:bg-slate-800 rounded-xl shadow-lg border z-50 max-h-96 overflow-y-auto">{results.map(result => (<button key={result.id} onClick={() => { onSelect(result); setQuery(""); setShowResults(false); }} className="w-full text-left px-4 py-2 hover:bg-slate-50 border-b last:border-0"><div className="flex items-center gap-3">{getIcon(result.type)}<div><p className="text-sm font-medium">{result.type === "lead" ? result.name : result.type === "vehicle" ? `${result.year} ${result.make} ${result.model}` : result.title}</p><p className="text-xs text-slate-500">{result.type === "lead" ? `${result.vehicle} • ${result.company}` : result.type === "vehicle" ? `Stock #${result.stock} • ${result.price.toLocaleString()}` : `Due: ${result.due}`}</p></div></div></button>))}</div>)}</div>);
};

const LeadDrawer = ({ lead, onClose, onAction }) => {
  if (!lead) return null;
  return (<div className="fixed inset-y-0 right-0 w-full max-w-md bg-white dark:bg-slate-800 shadow-2xl z-50 transform transition-transform border-l" style={{ animation: 'slide-in 0.3s ease-out' }}><div className="flex flex-col h-full"><div className="flex justify-between items-center p-5 border-b"><h2 className="text-xl font-semibold">Lead Details</h2><button onClick={onClose} className="p-1 hover:bg-slate-100 rounded-lg"><X size={20} /></button></div><div className="flex-1 overflow-y-auto p-5 space-y-5"><div className="flex items-center gap-4"><div className="w-16 h-16 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-xl font-bold">{lead.name.split(' ').map(n => n[0]).join('')}</div><div><h3 className="text-lg font-semibold">{lead.name}</h3><div className="flex items-center gap-2 mt-1"><StatusBadge status={lead.status} /><span className="text-sm text-slate-500">Score: {lead.score}/100</span></div><p className="text-xs text-slate-500 mt-1">{lead.title} at {lead.company}</p></div></div><div className="space-y-3"><h4 className="font-medium text-sm text-slate-500 uppercase">Contact Info</h4><div className="flex items-center gap-2 text-sm"><Phone size={16} className="text-slate-400" /><a href={`tel:${lead.phone}`} className="hover:text-indigo-600">{lead.phone}</a></div><div className="flex items-center gap-2 text-sm"><Mail size={16} className="text-slate-400" /><a href={`mailto:${lead.email}`} className="hover:text-indigo-600">{lead.email}</a></div><div className="flex items-center gap-2 text-sm"><Briefcase size={16} className="text-slate-400" /><span>{lead.title} at {lead.company}</span></div><div className="flex items-center gap-2 text-sm"><Clock size={16} className="text-slate-400" /><span>Best time: {lead.bestTime}</span></div></div><div className="space-y-3"><h4 className="font-medium text-sm text-slate-500 uppercase">Vehicle Interest</h4><div className="bg-slate-50 rounded-lg p-3"><p className="font-medium">{lead.vehicle}</p><p className="text-sm text-slate-500 mt-1">Budget: ${lead.budget.toLocaleString()}</p><p className="text-sm text-slate-500">Interest: {lead.interest}</p><p className="text-sm text-slate-500">Lead Value: ${lead.leadValue.toLocaleString()}</p><p className="text-sm text-slate-500">Probability: {lead.probability}%</p></div></div><div className="space-y-3"><h4 className="font-medium text-sm text-slate-500 uppercase">Lead Score Explanation</h4><div className="bg-indigo-50 rounded-lg p-3"><p className="text-sm">Scored {lead.score}/100 — visited site {lead.websiteVisits}x, opened {lead.emailsOpened} emails, {lead.tradeInSubmitted ? "submitted a trade-in form" : "no trade-in yet"}</p><div className="w-full bg-slate-200 rounded-full h-1.5 mt-2"><div className="bg-indigo-600 h-1.5 rounded-full" style={{ width: `${lead.probability}%` }}></div></div></div></div><div className="space-y-3"><h4 className="font-medium text-sm text-slate-500 uppercase">AI Suggested Next Action</h4><div className="bg-gradient-to-r from-indigo-500 to-purple-500 rounded-lg p-3 text-white"><div className="flex items-center gap-2 mb-2"><Sparkles size={16} /><span className="font-medium">AI Assistant</span></div><p className="text-sm">Based on {lead.websiteVisits} site visits and {lead.emailsOpened} opened emails, this customer is ready for a payment quote. Send now?</p><button className="mt-3 px-4 py-2 bg-white/20 rounded-lg text-sm font-medium hover:bg-white/30">Send Quote</button></div></div><div className="space-y-3"><h4 className="font-medium text-sm text-slate-500 uppercase">Quick Actions</h4><div className="grid grid-cols-2 gap-2"><button onClick={() => onAction("Call", lead)} className="flex items-center justify-center gap-2 px-3 py-2 bg-slate-100 rounded-lg text-sm"><Phone size={14} /> Call</button><button onClick={() => onAction("Text", lead)} className="flex items-center justify-center gap-2 px-3 py-2 bg-slate-100 rounded-lg text-sm"><MessageSquare size={14} /> Text</button><button onClick={() => onAction("Email", lead)} className="flex items-center justify-center gap-2 px-3 py-2 bg-slate-100 rounded-lg text-sm"><Mail size={14} /> Email</button><button onClick={() => onAction("Appointment", lead)} className="flex items-center justify-center gap-2 px-3 py-2 bg-slate-100 rounded-lg text-sm"><Calendar size={14} /> Set Appt</button></div></div></div></div></div>);
};

const AiAssistant = ({ onClose, onSendMessage }) => {
  const [messages, setMessages] = useState([{ role: "assistant", content: "Hello! I'm your AI sales assistant. Ask me about leads, inventory, performance, or anything else!" }]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const handleSend = () => {
    if (!input.trim()) return;
    setMessages(prev => [...prev, { role: "user", content: input }]);
    setInput("");
    setLoading(true);
    setTimeout(() => {
      let response = "";
      const lower = input.toLowerCase();
      if (lower.includes("hot lead")) response = "🔥 Your hottest leads:\n• Thomas Bennett (92) - F-150, 85% probability\n• Brandon Hayes (95) - Corvette, 95% probability\n• Rachel Cohen (88) - Mercedes GLE, 80% probability\n\nCall them within the hour!";
      else if (lower.includes("close rate")) response = "📊 Monthly close rate: 41.2%\nTop performers:\n• David Kim: 47.7%\n• Mike Rodriguez: 46.2%\n• Lisa Thompson: 41.5%";
      else if (lower.includes("inventory")) response = "🚗 Inventory summary:\n• 8 vehicles total, $491,940 value\n• Ford F-150 has highest engagement\n• Mercedes GLE priced $1,200 below market";
      else if (lower.includes("revenue")) response = "💰 Revenue YTD: $4.2M\n• Q1: $1.1M\n• Q2: $1.4M\n• Q3: $1.7M\nOn track for record year!";
      else response = "Based on your data:\n\n📈 Top opportunities: 5 hot leads ready\n🎯 Focus on Facebook leads (1500% ROI)\n📊 Forecast: 87 units this month\n💡 Send quotes to Thomas and Brandon today!";
      setMessages(prev => [...prev, { role: "assistant", content: response }]);
      setLoading(false);
      onSendMessage(input);
    }, 1000);
  };
  return (<div className="fixed inset-y-0 right-0 w-96 bg-white dark:bg-slate-800 shadow-2xl z-50 flex flex-col border-l"><div className="flex justify-between items-center p-4 border-b"><div className="flex items-center gap-2"><Bot size={20} className="text-indigo-500" /><h3 className="font-semibold">AI Assistant</h3><span className="text-xs px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-full">Powered by AI</span></div><button onClick={onClose} className="p-1 hover:bg-slate-100 rounded"><X size={18} /></button></div><div className="flex-1 overflow-y-auto p-4 space-y-3">{messages.map((msg, idx) => (<div key={idx} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}><div className={`max-w-[85%] p-3 rounded-xl ${msg.role === 'user' ? 'bg-indigo-500 text-white' : 'bg-slate-100'}`}><p className="text-sm whitespace-pre-line">{msg.content}</p></div></div>))}{loading && (<div className="flex justify-start"><div className="bg-slate-100 p-3 rounded-xl"><Loader2 size={16} className="animate-spin" /></div></div>)}</div><div className="p-4 border-t"><div className="flex gap-2"><input type="text" value={input} onChange={(e) => setInput(e.target.value)} onKeyPress={(e) => e.key === 'Enter' && handleSend()} placeholder="Ask anything..." className="flex-1 px-3 py-2 border rounded-lg bg-slate-50 text-sm" /><button onClick={handleSend} className="p-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600"><Send size={16} /></button></div><div className="flex gap-2 mt-2"><button onClick={() => setInput("Who are my hottest leads?")} className="text-xs px-2 py-1 bg-slate-100 rounded-full">Hot Leads</button><button onClick={() => setInput("What's my close rate?")} className="text-xs px-2 py-1 bg-slate-100 rounded-full">Close Rate</button><button onClick={() => setInput("Inventory performance?")} className="text-xs px-2 py-1 bg-slate-100 rounded-full">Inventory</button><button onClick={() => setInput("Revenue forecast?")} className="text-xs px-2 py-1 bg-slate-100 rounded-full">Revenue</button></div></div></div>);
};

const NotificationCenter = ({ notifications, onClose, onMarkRead }) => (<div className="absolute right-0 top-full mt-2 w-80 bg-white dark:bg-slate-800 rounded-xl shadow-lg border z-50 overflow-hidden"><div className="flex justify-between items-center p-4 border-b"><h3 className="font-semibold">Notifications</h3><button onClick={onClose} className="p-1 hover:bg-slate-100 rounded"><X size={16} /></button></div><div className="max-h-96 overflow-y-auto">{notifications.map(notif => (<div key={notif.id} className={`p-4 hover:bg-slate-50 border-b cursor-pointer ${!notif.read ? 'bg-indigo-50' : ''}`} onClick={() => onMarkRead(notif.id)}><div className="flex items-start gap-3"><div className={`p-1.5 rounded-full ${notif.type === 'lead' ? 'bg-emerald-100' : notif.type === 'alert' ? 'bg-amber-100' : 'bg-indigo-100'}`}>{notif.type === 'lead' ? <UserPlus size={12} className="text-emerald-600" /> : notif.type === 'alert' ? <AlertCircle size={12} className="text-amber-600" /> : <Calendar size={12} className="text-indigo-600" />}</div><div className="flex-1"><p className="text-sm">{notif.message}</p><p className="text-xs text-slate-500 mt-1">{notif.time}</p></div>{!notif.read && <div className="w-2 h-2 bg-indigo-500 rounded-full"></div>}</div></div>))}</div></div>);

// ==================== ULTIMATE DASHBOARD ====================
const Dashboard = ({ onToast, onSelectLead }) => {
  const totalRevenue = salespeople.reduce((sum, r) => sum + r.revenue, 0);
  const totalLeads = leadsData.length;
  const conversionRate = ((salespeople.reduce((sum, r) => sum + r.units, 0) / totalLeads) * 100).toFixed(1);
  
  return (
    <div className="space-y-6">
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        <KpiCard title="New Leads Today" value="23" change="+12%" icon={Users} color="bg-indigo-500" subtitle="vs yesterday" />
        <KpiCard title="Appointments" value="18" change="+5" icon={Calendar} color="bg-emerald-500" subtitle="67% show rate" />
        <KpiCard title="Revenue MTD" value={`$${(totalRevenue/1000000).toFixed(1)}M`} change="+8%" icon={DollarSign} color="bg-amber-500" subtitle="vs target" />
        <KpiCard title="Conversion Rate" value={`${conversionRate}%`} change="+2.1%" icon={Target} color="bg-rose-500" subtitle="industry avg 18%" />
      </div>
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Lead Volume Trend</h3><ResponsiveContainer width="100%" height={300}><AreaChart data={leadVolumeData}><CartesianGrid strokeDasharray="3 3" /><XAxis dataKey="day" /><YAxis /><Tooltip /><Area type="monotone" dataKey="leads" stroke="#4F46E5" fill="#4F46E5" fillOpacity={0.1} /><Area type="monotone" dataKey="conversions" stroke="#10B981" fill="#10B981" fillOpacity={0.1} /></AreaChart></ResponsiveContainer></div>
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Lead Sources ROI</h3><ResponsiveContainer width="100%" height={300}><RePieChart><Pie data={leadSourcesData} cx="50%" cy="50%" innerRadius={60} outerRadius={100} paddingAngle={5} dataKey="value" label={({ name, percent }) => `${name} ${(percent * 100).toFixed(0)}%`}>{leadSourcesData.map((entry, idx) => <Cell key={idx} fill={entry.color} />)}</Pie><Tooltip /></RePieChart></ResponsiveContainer></div>
      </div>
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Team Performance</h3><ResponsiveContainer width="100%" height={300}><ReBarChart data={salespersonPerformance}><CartesianGrid strokeDasharray="3 3" /><XAxis dataKey="name" /><YAxis yAxisId="left" /><YAxis yAxisId="right" orientation="right" /><Tooltip /><Legend /><Bar yAxisId="left" dataKey="units" fill="#4F46E5" name="Units" /><Bar yAxisId="right" dataKey="gross" fill="#10B981" name="Gross ($K)" /></ReBarChart></ResponsiveContainer></div>
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4 flex items-center justify-between"><span>🔥 Hot Leads</span><span className="text-xs text-rose-500 animate-pulse">● Live</span></h3><div className="space-y-3 max-h-[300px] overflow-y-auto">{hotLeads.map(lead => (<div key={lead.id} className="flex items-center justify-between p-3 bg-slate-50 rounded-lg cursor-pointer hover:bg-slate-100" onClick={() => onSelectLead(lead)}><div><div className="flex items-center gap-2"><p className="font-medium text-sm">{lead.name}</p><StatusBadge status={lead.status} /></div><p className="text-xs text-slate-500">{lead.vehicle}</p><p className="text-xs text-slate-400">{lead.lastActivity}</p></div><div className="flex gap-2"><button onClick={(e) => { e.stopPropagation(); onToast(`Calling ${lead.name}...`, "info"); }} className="p-2 bg-emerald-100 rounded-lg"><Phone size={14} className="text-emerald-600" /></button><button onClick={(e) => { e.stopPropagation(); onToast(`Texting ${lead.name}...`, "info"); }} className="p-2 bg-indigo-100 rounded-lg"><MessageSquare size={14} className="text-indigo-600" /></button></div></div>))}</div></div>
      </div>
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border lg:col-span-2"><h3 className="font-semibold mb-4">Financial Performance</h3><ResponsiveContainer width="100%" height={250}><ComposedChart data={monthlyGoals.slice(-6)}><CartesianGrid strokeDasharray="3 3" /><XAxis dataKey="month" /><YAxis /><Tooltip /><Legend /><Bar dataKey="target" fill="#4F46E5" name="Target" /><Bar dataKey="actual" fill="#10B981" name="Actual" /></ComposedChart></ResponsiveContainer></div>
        <div className="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border"><h3 className="font-semibold mb-4">Customer Satisfaction</h3><div className="text-center"><div className="text-5xl font-bold text-indigo-600">4.7</div><div className="flex justify-center gap-1 my-2">{[...Array(5)].map((_, i) => (<Star key={i} size={20} className={i < 4.7 ? "text-yellow-400 fill-yellow-400" : "text-slate-300"} />))}</div><p className="text-sm text-slate-500">Based on 247 reviews</p><div className="mt-3 p-2 bg-emerald-50 rounded-lg"><p className="text-sm">"Best car buying experience!" - John S.</p></div></div></div>
      </div>
    </div>
  );
};

// ==================== ULTIMATE LEADS PAGE ====================
const LeadsPage = ({ onToast, onSelectLead }) => {
  const [search, setSearch] = useState("");
  const [filterStatus, setFilterStatus] = useState("all");
  const [filterSource, setFilterSource] = useState("all");
  const [filterRep, setFilterRep] = useState("all");
  const [viewMode, setViewMode] = useState("table");
  const filteredLeads = leadsData.filter(lead => { if (filterStatus !== "all" && lead.status !== filterStatus) return false; if (filterSource !== "all" && lead.source !== filterSource) return false; if (filterRep !== "all" && lead.rep !== filterRep) return false; if (search && !lead.name.toLowerCase().includes(search.toLowerCase()) && !lead.vehicle.toLowerCase().includes(search.toLowerCase())) return false; return true; });
  const uniqueSources = [...new Set(leadsData.map(l => l.source))];
  const uniqueReps = [...new Set(leadsData.map(l => l.rep))];
  const totalValue = filteredLeads.reduce((sum, l) => sum + l.leadValue, 0);
  const avgScore = Math.floor(filteredLeads.reduce((sum, l) => sum + l.score, 0) / filteredLeads.length);
  
  if (viewMode === "grid") {
    return (<div className="space-y-5"><div className="flex flex-wrap gap-3 items-center justify-between"><div className="flex gap-2"><select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className="px-3 py-2 border rounded-lg text-sm"><option value="all">Status</option><option value="Hot">Hot</option><option value="Warm">Warm</option><option value="Cold">Cold</option></select><select value={filterSource} onChange={(e) => setFilterSource(e.target.value)} className="px-3 py-2 border rounded-lg text-sm"><option value="all">Source</option>{uniqueSources.map(s => <option key={s} value={s}>{s}</option>)}</select><input type="text" placeholder="Search..." value={search} onChange={(e) => setSearch(e.target.value)} className="px-3 py-2 border rounded-lg text-sm w-64" /></div><div className="flex gap-2"><button onClick={() => setViewMode("table")} className="px-3 py-2 bg-slate-100 rounded-lg">📋 Table</button><button onClick={() => setViewMode("grid")} className="px-3 py-2 bg-indigo-100 text-indigo-600 rounded-lg">📱 Grid</button></div></div><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">{filteredLeads.map(lead => (<div key={lead.id} className="bg-white dark:bg-slate-800 rounded-xl p-4 border hover:shadow-md cursor-pointer" onClick={() => onSelectLead(lead)}><div className="flex justify-between items-start mb-2"><div className="flex items-center gap-2"><div className="w-10 h-10 rounded-full bg-gradient-to-r from-indigo-500 to-purple-500 flex items-center justify-center text-white font-bold">{lead.name.charAt(0)}</div><div><p className="font-medium">{lead.name}</p><p className="text-xs text-slate-500">{lead.company}</p></div></div><StatusBadge status={lead.status} /></div><p className="text-sm font-medium mt-1">{lead.vehicle.split(' ').slice(0,3).join(' ')}</p><div className="flex justify-between text-xs text-slate-500 mt-2"><span>{lead.source}</span><span>${lead.leadValue.toLocaleString()}</span><span>{lead.lastActivity}</span></div><div className="flex gap-2 mt-3"><button className="flex-1 py-1.5 bg-slate-100 rounded text-sm">Contact</button><button className="flex-1 py-1.5 bg-indigo-50 text-indigo-600 rounded text-sm">Details</button></div></div>))}</div></div>);
  }
  
  return (<div className="space-y-5"><div className="grid grid-cols-1 md:grid-cols-4 gap-4"><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-indigo-600">{filteredLeads.length}</p><p className="text-sm text-slate-500">Total Leads</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-emerald-600">${(totalValue/1000).toFixed(0)}K</p><p className="text-sm text-slate-500">Pipeline Value</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-amber-600">{filteredLeads.filter(l => l.status === "Hot").length}</p><p className="text-sm text-slate-500">Hot Leads</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-rose-600">{avgScore}</p><p className="text-sm text-slate-500">Avg Score</p></div></div><div className="flex flex-wrap gap-3 items-center justify-between"><div className="flex flex-wrap gap-2"><select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className="px-3 py-2 border rounded-lg text-sm"><option value="all">Status</option><option value="Hot">Hot</option><option value="Warm">Warm</option><option value="Cold">Cold</option></select><select value={filterSource} onChange={(e) => setFilterSource(e.target.value)} className="px-3 py-2 border rounded-lg text-sm"><option value="all">Source</option>{uniqueSources.map(s => <option key={s} value={s}>{s}</option>)}</select><select value={filterRep} onChange={(e) => setFilterRep(e.target.value)} className="px-3 py-2 border rounded-lg text-sm"><option value="all">Rep</option>{uniqueReps.map(r => <option key={r} value={r}>{r.split(' ')[0]}</option>)}</select><input type="text" placeholder="Search..." value={search} onChange={(e) => setSearch(e.target.value)} className="px-3 py-2 border rounded-lg text-sm w-64" /></div><div className="flex gap-2"><button onClick={() => setViewMode("table")} className="px-3 py-2 bg-indigo-100 text-indigo-600 rounded-lg">📋 Table</button><button onClick={() => setViewMode("grid")} className="px-3 py-2 bg-slate-100 rounded-lg">📱 Grid</button><button className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm flex items-center gap-2"><Filter size={16} /> Advanced</button></div></div><div className="bg-white dark:bg-slate-800 rounded-xl shadow-sm border overflow-hidden"><div className="overflow-x-auto"><table className="w-full"><thead className="bg-slate-50"><tr className="text-left text-xs font-medium text-slate-500 uppercase"><th className="px-4 py-3">Score</th><th className="px-4 py-3">Customer</th><th className="px-4 py-3">Contact</th><th className="px-4 py-3">Vehicle</th><th className="px-4 py-3">Value</th><th className="px-4 py-3">Source</th><th className="px-4 py-3">Status</th><th className="px-4 py-3">Rep</th><th className="px-4 py-3">Last Activity</th><th className="px-4 py-3">Actions</th></tr></thead><tbody className="divide-y">{filteredLeads.map(lead => (<tr key={lead.id} className="hover:bg-slate-50 cursor-pointer" onClick={() => onSelectLead(lead)}><td className="px-4 py-3"><span className={`inline-flex px-2 py-0.5 rounded-full text-xs ${lead.score >= 80 ? 'bg-rose-100 text-rose-700' : lead.score >= 60 ? 'bg-amber-100 text-amber-700' : 'bg-slate-100'}`}>{lead.score}</span></td><td className="px-4 py-3"><div><p className="font-medium text-sm">{lead.name}</p><p className="text-xs text-slate-500">{lead.company}</p></div></td><td className="px-4 py-3"><div className="flex gap-1"><a href={`tel:${lead.phone}`} onClick={(e) => e.stopPropagation()} className="p-1 hover:bg-slate-100 rounded"><Phone size={14} /></a><a href={`mailto:${lead.email}`} onClick={(e) => e.stopPropagation()} className="p-1 hover:bg-slate-100 rounded"><Mail size={14} /></a></div></td><td className="px-4 py-3 text-sm">{lead.vehicle.split(' ').slice(0,2).join(' ')}</td><td className="px-4 py-3 text-sm font-medium text-emerald-600">${(lead.leadValue/1000).toFixed(0)}K</td><td className="px-4 py-3 text-sm">{lead.source}</td><td className="px-4 py-3"><StatusBadge status={lead.status} /></td><td className="px-4 py-3 text-sm">{lead.rep.split(' ')[0]}</td><td className="px-4 py-3 text-sm text-slate-500">{lead.lastActivity}</td><td className="px-4 py-3"><div className="flex gap-1"><button onClick={(e) => { e.stopPropagation(); onToast(`Calling ${lead.name}`, "info"); }} className="p-1.5 hover:bg-slate-100 rounded"><PhoneCall size={14} /></button><button onClick={(e) => { e.stopPropagation(); onToast(`Texting ${lead.name}`, "info"); }} className="p-1.5 hover:bg-slate-100 rounded"><MessageSquare size={14} /></button><button onClick={(e) => { e.stopPropagation(); onToast(`Setting appointment for ${lead.name}`, "success"); }} className="p-1.5 hover:bg-slate-100 rounded"><Calendar size={14} /></button></div></td></tr>))}</tbody></table></div></div></div>);
};

// ==================== ULTIMATE INVENTORY PAGE ====================
const InventoryPage = ({ onToast }) => {
  const [filterType, setFilterType] = useState("all");
  const [selectedVehicle, setSelectedVehicle] = useState(null);
  const filteredInventory = inventoryData.filter(v => filterType === "all" || v.type === filterType);
  const totalValue = filteredInventory.reduce((sum, v) => sum + v.price, 0);
  const avgDays = Math.floor(filteredInventory.reduce((sum, v) => sum + v.daysOnLot, 0) / filteredInventory.length);
  
  return (<div className="space-y-5"><div className="grid grid-cols-1 md:grid-cols-4 gap-4"><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-indigo-600">{filteredInventory.length}</p><p className="text-sm text-slate-500">Vehicles</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-emerald-600">${(totalValue/1000).toFixed(0)}K</p><p className="text-sm text-slate-500">Total Value</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-amber-600">{avgDays}</p><p className="text-sm text-slate-500">Avg Days on Lot</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-rose-600">{filteredInventory.filter(v => v.status === "Available").length}</p><p className="text-sm text-slate-500">Available</p></div></div><div className="flex flex-wrap gap-3 items-center justify-between"><div className="flex gap-2"><div className="flex bg-slate-100 rounded-lg p-1">{["all", "New", "Used"].map(type => (<button key={type} onClick={() => setFilterType(type.toLowerCase())} className={`px-4 py-1.5 text-sm rounded-md ${filterType === type.toLowerCase() ? 'bg-white shadow-sm' : ''}`}>{type === "all" ? "All" : type}</button>))}</div><select className="px-3 py-2 border rounded-lg text-sm"><option>All Makes</option><option>Ford</option><option>Tesla</option><option>BMW</option><option>Mercedes</option></select><input type="range" min="0" max="100000" className="w-32" /></div><button onClick={() => onToast("Add vehicle form opened", "success")} className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ Add Vehicle</button></div><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">{filteredInventory.map(vehicle => (<div key={vehicle.id} className="bg-white dark:bg-slate-800 rounded-xl shadow-sm border overflow-hidden hover:shadow-md transition-all cursor-pointer group" onClick={() => setSelectedVehicle(vehicle)}><div className="h-32 bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-lg font-bold relative group-hover:scale-105 transition-transform">{vehicle.make} {vehicle.model}<div className={`absolute top-2 right-2 w-2 h-2 rounded-full ${vehicle.status === "Available" ? "bg-emerald-400 animate-pulse" : "bg-slate-400"}`}></div></div><div className="p-4"><div className="flex justify-between items-start mb-2"><div><h3 className="font-semibold">{vehicle.year} {vehicle.make} {vehicle.model}</h3><p className="text-xs text-slate-500">Stock #{vehicle.stock}</p></div><StatusBadge status={vehicle.status} /></div><div className="flex justify-between items-center mb-3"><p className="text-xl font-bold text-indigo-600">${vehicle.price.toLocaleString()}</p><div className="flex gap-2 text-xs"><span className="px-2 py-1 bg-slate-100 rounded">👁️ {vehicle.views}</span><span className="px-2 py-1 bg-emerald-100 rounded">📞 {vehicle.inquiries}</span></div></div><div className="flex gap-2"><button onClick={(e) => { e.stopPropagation(); onToast(`Matching leads for ${vehicle.model}`, "success"); }} className="flex-1 py-2 bg-indigo-50 text-indigo-600 rounded-lg text-sm">Match to Lead</button><button className="flex-1 py-2 bg-slate-100 rounded-lg text-sm">Details</button></div></div></div>))}</div>{selectedVehicle && (<div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50" onClick={() => setSelectedVehicle(null)}><div className="bg-white dark:bg-slate-800 rounded-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto" onClick={(e) => e.stopPropagation()}><div className="sticky top-0 bg-white dark:bg-slate-800 p-5 border-b flex justify-between items-center"><h2 className="text-xl font-semibold">{selectedVehicle.year} {selectedVehicle.make} {selectedVehicle.model}</h2><button onClick={() => setSelectedVehicle(null)} className="p-1 hover:bg-slate-100 rounded"><X size={20} /></button></div><div className="p-5 space-y-5"><div className="h-40 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-xl flex items-center justify-center text-white text-2xl font-bold">{selectedVehicle.make} {selectedVehicle.model}</div><div className="grid grid-cols-2 gap-4"><div><p className="text-sm text-slate-500">Price</p><p className="text-2xl font-bold text-indigo-600">${selectedVehicle.price.toLocaleString()}</p></div><div><p className="text-sm text-slate-500">Market Comparison</p><p className="text-emerald-600 text-sm font-medium">$1,200 below market</p></div><div><p className="text-sm text-slate-500">Engine</p><p className="font-medium">{selectedVehicle.engine}</p></div><div><p className="text-sm text-slate-500">MPG</p><p className="font-medium">{selectedVehicle.mpg}</p></div><div><p className="text-sm text-slate-500">Color</p><p className="font-medium">{selectedVehicle.color}</p></div><div><p className="text-sm text-slate-500">VIN</p><p className="font-mono text-sm">{selectedVehicle.vin}</p></div></div><div><p className="text-sm text-slate-500 mb-2">Features</p><div className="flex flex-wrap gap-2">{selectedVehicle.features.map((f, i) => (<span key={i} className="px-2 py-1 bg-slate-100 rounded-lg text-xs">{f}</span>))}</div></div><div className="flex gap-3"><button className="flex-1 bg-indigo-600 text-white py-2 rounded-lg font-medium">Contact Leads</button><button className="flex-1 bg-slate-100 py-2 rounded-lg">Test Drive</button></div></div></div></div>)}</div>);
};

// ==================== ULTIMATE SERVICE PAGE ====================
const ServicePage = ({ onToast }) => {
  const [appointments, setAppointments] = useState(serviceAppointments);
  const [filterStatus, setFilterStatus] = useState("all");
  const filteredAppointments = appointments.filter(apt => filterStatus === "all" || apt.status === filterStatus);
  const updateStatus = (id, newStatus) => { setAppointments(appointments.map(apt => apt.id === id ? { ...apt, status: newStatus } : apt)); onToast(`RO #${id} updated to ${newStatus}`, "success"); };
  const stats = { total: appointments.length, inProgress: appointments.filter(a => a.status === "In Progress").length, waiting: appointments.filter(a => a.status === "Waiting").length, withTech: appointments.filter(a => a.status === "With Tech").length, ready: appointments.filter(a => a.status === "Ready").length, completed: appointments.filter(a => a.status === "Completed").length };
  const totalRevenue = appointments.reduce((sum, a) => sum + a.cost, 0);
  
  return (<div className="flex gap-6"><div className="flex-1"><div className="mb-4 flex flex-wrap gap-2">{["all", "Scheduled", "Waiting", "In Progress", "With Tech", "Ready", "Completed"].map(status => (<button key={status} onClick={() => setFilterStatus(status.toLowerCase())} className={`px-3 py-1.5 text-sm rounded-lg ${filterStatus === status.toLowerCase() ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-100'}`}>{status === "all" ? "All" : status}</button>))}</div><div className="bg-white dark:bg-slate-800 rounded-xl shadow-sm border overflow-hidden"><div className="grid grid-cols-12 gap-2 p-3 bg-slate-50 text-xs font-medium"><div className="col-span-2">Time</div><div className="col-span-3">Customer/Vehicle</div><div className="col-span-3">Service</div><div className="col-span-2">Advisor/Tech</div><div className="col-span-2">Status</div></div><div className="divide-y">{filteredAppointments.map(apt => (<div key={apt.id} className="grid grid-cols-12 gap-2 p-3 items-center hover:bg-slate-50"><div className="col-span-2"><p className="font-bold text-indigo-600 text-sm">{apt.time}</p></div><div className="col-span-3"><p className="font-medium text-sm">{apt.customer}</p><p className="text-xs text-slate-500">{apt.vehicle}</p></div><div className="col-span-3"><p className="text-sm">{apt.service}</p><p className="text-xs text-slate-500">${apt.cost} · {apt.duration}min</p></div><div className="col-span-2"><p className="text-sm">{apt.advisor}</p><p className="text-xs text-slate-500">Tech: {apt.tech || "Pending"}</p></div><div className="col-span-2"><select value={apt.status} onChange={(e) => updateStatus(apt.id, e.target.value)} className="px-2 py-1 text-xs border rounded-lg"><option>Scheduled</option><option>Waiting</option><option>In Progress</option><option>With Tech</option><option>Ready</option><option>Completed</option></select></div></div>))}</div></div></div><div className="w-64 space-y-3"><div className="bg-white dark:bg-slate-800 rounded-xl p-4 border"><p className="text-2xl font-bold">{stats.total}</p><p className="text-sm text-slate-500">Total ROs</p><div className="flex justify-between text-xs mt-2"><span>📋 {stats.inProgress}</span><span>⏳ {stats.waiting}</span><span>🔧 {stats.withTech}</span></div></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 border"><p className="text-2xl font-bold text-emerald-600">${totalRevenue}</p><p className="text-sm text-slate-500">Service Revenue</p><p className="text-xs text-emerald-600 mt-1">+12% vs last month</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 border"><p className="text-2xl font-bold">4.8</p><p className="text-sm text-slate-500">CSI Score</p><div className="flex gap-0.5 mt-1">{[...Array(5)].map((_, i) => (<Star key={i} size={12} className={i < 4.8 ? "text-yellow-400 fill-yellow-400" : "text-slate-300"} />))}</div></div><button onClick={() => onToast("New RO created", "success")} className="w-full py-2 bg-indigo-600 text-white rounded-lg text-sm">+ New RO</button></div></div>);
};

// ==================== ULTIMATE CAMPAIGNS PAGE ====================
const CampaignsPage = ({ onToast }) => {
  const [activeTab, setActiveTab] = useState("active");
  const campaigns = [...campaignsData];
  const filteredCampaigns = campaigns.filter(c => activeTab === "all" || (activeTab === "active" ? c.status !== "completed" : c.status === "completed"));
  const totalRevenue = filteredCampaigns.reduce((sum, c) => sum + c.revenue, 0);
  
  return (<div className="space-y-5"><div className="flex justify-between items-center"><h2 className="text-xl font-semibold">Marketing Campaigns</h2><button onClick={() => onToast("New campaign created", "success")} className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ New Campaign</button></div><div className="grid grid-cols-1 md:grid-cols-4 gap-4"><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-indigo-600">{campaigns.length}</p><p className="text-sm text-slate-500">Total Campaigns</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-emerald-600">${(totalRevenue/1000).toFixed(0)}K</p><p className="text-sm text-slate-500">Total Revenue</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-amber-600">{campaigns.reduce((sum, c) => sum + c.sent, 0).toLocaleString()}</p><p className="text-sm text-slate-500">Messages Sent</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-rose-600">{Math.round(campaigns.reduce((sum, c) => sum + c.openRate, 0) / campaigns.length)}%</p><p className="text-sm text-slate-500">Avg Open Rate</p></div></div><div className="flex gap-2 border-b pb-2">{["active", "completed", "all"].map(tab => (<button key={tab} onClick={() => setActiveTab(tab)} className={`px-4 py-2 text-sm rounded-lg ${activeTab === tab ? 'bg-indigo-100 text-indigo-700' : 'hover:bg-slate-100'}`}>{tab.charAt(0).toUpperCase() + tab.slice(1)}</button>))}</div><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-5">{filteredCampaigns.map(campaign => (<div key={campaign.id} className="bg-white dark:bg-slate-800 rounded-xl p-5 border hover:shadow-md"><div className="flex justify-between items-start mb-3"><div><h3 className="font-semibold">{campaign.name}</h3><p className="text-xs text-slate-500">{campaign.type} Campaign</p></div><StatusBadge status={campaign.status === "active" ? "active" : "inactive"} /></div><div className="grid grid-cols-4 gap-2 text-center mb-3"><div><p className="text-lg font-bold">{campaign.sent.toLocaleString()}</p><p className="text-xs text-slate-500">Sent</p></div><div><p className="text-lg font-bold">{campaign.openRate}%</p><p className="text-xs text-slate-500">Open</p></div><div><p className="text-lg font-bold">{campaign.clickRate}%</p><p className="text-xs text-slate-500">Click</p></div><div><p className="text-lg font-bold">${(campaign.revenue/1000).toFixed(0)}K</p><p className="text-xs text-slate-500">Revenue</p></div></div><div className="w-full bg-slate-200 rounded-full h-1.5 mb-3"><div className="bg-indigo-600 h-1.5 rounded-full" style={{ width: `${campaign.conversionRate * 10}%` }}></div></div><div className="flex gap-2"><button className="flex-1 py-2 text-indigo-600 text-sm font-medium hover:bg-indigo-50 rounded-lg">Analytics</button><button className="flex-1 py-2 bg-slate-100 rounded-lg text-sm">Edit</button></div></div>))}</div></div>);
};

// ==================== ULTIMATE ANALYTICS PAGE ====================
const AnalyticsPage = ({ onToast }) => {
  const [dateRange, setDateRange] = useState("mtd");
  const totalUnits = salespeople.reduce((sum, r) => sum + r.units, 0);
  const totalGross = salespeople.reduce((sum, r) => sum + r.gross, 0);
  const avgCloseRate = salespeople.reduce((sum, r) => sum + r.closeRate, 0) / salespeople.length;
  const totalLeads = leadsData.length;
  
  return (<div className="space-y-6"><div className="flex justify-between items-center flex-wrap gap-3"><div className="flex gap-2 bg-slate-100 rounded-lg p-1">{["mtd", "lastMonth", "last90", "custom"].map(range => (<button key={range} onClick={() => setDateRange(range)} className={`px-4 py-1.5 text-sm rounded-md ${dateRange === range ? 'bg-white shadow-sm' : ''}`}>{range === "mtd" ? "MTD" : range === "lastMonth" ? "Last Month" : range === "last90" ? "Last 90 Days" : "Custom"}</button>))}</div><button onClick={() => onToast("Report exported", "success")} className="flex items-center gap-2 text-indigo-600 text-sm"><Download size={14} /> Export Full Report</button></div><div className="grid grid-cols-1 md:grid-cols-5 gap-4"><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold">{totalUnits}</p><p className="text-sm text-slate-500">Units Sold</p><p className="text-xs text-emerald-600">+12 vs last month</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-emerald-600">${(totalGross/1000).toFixed(0)}K</p><p className="text-sm text-slate-500">Gross Profit</p><p className="text-xs text-emerald-600">+8.5% margin</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-indigo-600">{avgCloseRate.toFixed(1)}%</p><p className="text-sm text-slate-500">Close Rate</p><p className="text-xs text-emerald-600">+2.3% vs target</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-amber-600">{totalLeads}</p><p className="text-sm text-slate-500">Total Leads</p><p className="text-xs text-emerald-600">+18% YoY</p></div><div className="bg-white dark:bg-slate-800 rounded-xl p-4 text-center border"><p className="text-2xl font-bold text-rose-600">${((totalGross/totalUnits)/1000).toFixed(0)}K</p><p className="text-sm text-slate-500">Avg Deal Size</p><p className="text-xs text-emerald-600">+$1,200 vs Q3</p></div></div><div className="grid grid-cols-1 lg:grid-cols-2 gap-6"><div className="bg-white dark:bg-slate-800 rounded-xl p-5 border"><h3 className="font-semibold mb-4">Sales Leaderboard</h3><div className="space-y-3">{[...salespeople].sort((a,b) => b.units - a.units).map((rep, idx) => (<div key={rep.id} className="flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg"><div className="flex items-center gap-3"><div className={`w-8 h-8 rounded-full ${rep.color} flex items-center justify-center text-white text-xs font-bold`}>{rep.initials}</div><div><p className="font-medium text-sm">{rep.name}</p><p className="text-xs text-slate-500">{rep.units} units · ${(rep.gross/1000).toFixed(0)}K gross</p></div></div><div className="text-right"><p className="font-medium text-emerald-600">{rep.closeRate}%</p><p className="text-xs text-slate-500">close rate</p></div></div>))}</div></div><div className="bg-white dark:bg-slate-800 rounded-xl p-5 border"><h3 className="font-semibold mb-4">Lead Source ROI</h3><ResponsiveContainer width="100%" height={300}><ReBarChart data={leadSourcesData}><CartesianGrid strokeDasharray="3 3" /><XAxis dataKey="name" /><YAxis yAxisId="left" /><YAxis yAxisId="right" orientation="right" /><Tooltip /><Legend /><Bar yAxisId="left" dataKey="costPerLead" fill="#4F46E5" name="Cost/Lead" /><Bar yAxisId="right" dataKey="roi" fill="#10B981" name="ROI %" /></ReBarChart></ResponsiveContainer></div></div><div className="grid grid-cols-1 lg:grid-cols-2 gap-6"><div className="bg-white dark:bg-slate-800 rounded-xl p-5 border"><h3 className="font-semibold mb-4">Lost Deal Reasons</h3><ResponsiveContainer width="100%" height={250}><RePieChart><Pie data={lostDealReasons} cx="50%" cy="50%" innerRadius={50} outerRadius={80} dataKey="value" label={({ name, percent }) => `${name} ${(percent * 100).toFixed(0)}%`}>{lostDealReasons.map((entry, idx) => <Cell key={idx} fill={entry.color} />)}</Pie><Tooltip /></RePieChart></ResponsiveContainer></div><div className="bg-white dark:bg-slate-800 rounded-xl p-5 border"><h3 className="font-semibold mb-4">Response Time Heatmap</h3><div className="overflow-x-auto"><table className="w-full text-sm"><thead><tr><th className="p-2"></th><th className="p-2">Mon</th><th className="p-2">Tue</th><th className="p-2">Wed</th><th className="p-2">Thu</th><th className="p-2">Fri</th></tr></thead><tbody>{responseTimeHeatmap.map(row => (<tr key={row.hour}><td className="p-2 font-medium">{row.hour}</td>{["Mon","Tue","Wed","Thu","Fri"].map(day => { const val = row[day]; return <td key={day} className="p-2"><div className={`px-2 py-1 rounded text-center text-white ${val > 5 ? 'bg-rose-500' : val > 4 ? 'bg-amber-500' : 'bg-emerald-500'}`}>{val}m</div></td>; })}</tr>))}</tbody></table></div><p className="text-xs text-slate-500 text-center mt-2">Best response time: 10am-12pm (avg 3.4 min)</p></div></div><div className="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl p-6 text-white"><p className="text-sm font-medium mb-2">📊 Forecast & Insights</p><p className="text-lg">On pace for {Math.round(totalUnits * 1.15)} units this month. Need {Math.max(0, 87 - totalUnits)} more to hit goal.</p><div className="mt-3 w-full bg-white/20 rounded-full h-2"><div className="bg-white h-2 rounded-full" style={{ width: `${(totalUnits / 87) * 100}%` }}></div></div><p className="text-xs mt-2 opacity-90">{Math.round((totalUnits / 87) * 100)}% of monthly goal achieved</p><div className="grid grid-cols-3 gap-3 mt-4"><div className="bg-white/20 rounded-lg p-2 text-center"><p className="text-lg font-bold">${((totalGross * 1.15)/1000).toFixed(0)}K</p><p className="text-xs">Projected Revenue</p></div><div className="bg-white/20 rounded-lg p-2 text-center"><p className="text-lg font-bold">{Math.round(totalUnits * 1.15)}</p><p className="text-xs">Projected Units</p></div><div className="bg-white/20 rounded-lg p-2 text-center"><p className="text-lg font-bold">+15%</p><p className="text-xs">Growth Rate</p></div></div><button className="mt-3 px-4 py-2 bg-white/20 rounded-lg text-sm font-medium hover:bg-white/30">View Detailed Forecast</button></div></div>);
};

// ==================== ULTIMATE SETTINGS PAGE ====================
const SettingsPage = ({ onToast }) => {
  const [notifications, setNotifications] = useState(true);
  const [autoAssign, setAutoAssign] = useState(true);
  const [emailDigest, setEmailDigest] = useState(true);
  const [slackIntegration, setSlackIntegration] = useState(false);
  
  return (<div className="space-y-6"><div className="bg-white dark:bg-slate-800 rounded-xl p-6 shadow-sm border"><h3 className="font-semibold mb-4 flex items-center gap-2"><Users size={18} /> User Management</h3><div className="space-y-3">{salespeople.map(user => (<div key={user.id} className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div className="flex items-center gap-3"><div className={`w-10 h-10 rounded-full ${user.color} flex items-center justify-center text-white font-bold`}>{user.initials}</div><div><p className="font-medium">{user.name}</p><p className="text-xs text-slate-500">Sales Consultant · {user.units} units</p></div></div><div className="flex gap-2"><button onClick={() => onToast(`Editing ${user.name}`, "info")} className="px-3 py-1 text-indigo-600 text-sm hover:bg-indigo-50 rounded">Edit</button><button onClick={() => onToast(`Removing ${user.name}`, "error")} className="px-3 py-1 text-rose-600 text-sm hover:bg-rose-50 rounded">Remove</button></div></div>))}<button onClick={() => onToast("Add user form opened", "success")} className="w-full mt-3 py-2 border-2 border-dashed border-slate-300 rounded-lg text-indigo-600 text-sm font-medium hover:bg-indigo-50">+ Add New User</button></div></div><div className="grid grid-cols-1 lg:grid-cols-2 gap-6"><div className="bg-white dark:bg-slate-800 rounded-xl p-6 shadow-sm border"><h3 className="font-semibold mb-4 flex items-center gap-2"><Settings size={18} /> Workflow Automations</h3><div className="space-y-3"><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div><p className="font-medium">Auto-assign Leads</p><p className="text-xs text-slate-500">Round-robin assignment to sales reps</p></div><button onClick={() => { setAutoAssign(!autoAssign); onToast(`Auto-assign ${!autoAssign ? 'enabled' : 'disabled'}`, "success"); }} className={`px-4 py-2 rounded-lg text-sm ${autoAssign ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-200'}`}>{autoAssign ? 'Enabled' : 'Disabled'}</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div><p className="font-medium">Lead Scoring</p><p className="text-xs text-slate-500">Auto-calculate lead scores</p></div><button className="px-4 py-2 bg-emerald-100 text-emerald-700 rounded-lg text-sm">Enabled</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div><p className="font-medium">Follow-up Reminders</p><p className="text-xs text-slate-500">Automated reminders for stale leads</p></div><button className="px-4 py-2 bg-emerald-100 text-emerald-700 rounded-lg text-sm">Enabled</button></div></div></div><div className="bg-white dark:bg-slate-800 rounded-xl p-6 shadow-sm border"><h3 className="font-semibold mb-4 flex items-center gap-2"><Bell size={18} /> Notification Preferences</h3><div className="space-y-3"><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div><p className="font-medium">Email Notifications</p><p className="text-xs text-slate-500">Receive email alerts</p></div><button onClick={() => { setNotifications(!notifications); onToast(`Email notifications ${!notifications ? 'enabled' : 'disabled'}`, "success"); }} className={`px-4 py-2 rounded-lg text-sm ${notifications ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-200'}`}>{notifications ? 'Enabled' : 'Disabled'}</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div><p className="font-medium">Daily Digest</p><p className="text-xs text-slate-500">Daily summary email</p></div><button onClick={() => { setEmailDigest(!emailDigest); onToast(`Daily digest ${!emailDigest ? 'enabled' : 'disabled'}`, "success"); }} className={`px-4 py-2 rounded-lg text-sm ${emailDigest ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-200'}`}>{emailDigest ? 'Enabled' : 'Disabled'}</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><div><p className="font-medium">Push Notifications</p><p className="text-xs text-slate-500">Browser notifications</p></div><button className="px-4 py-2 bg-emerald-100 text-emerald-700 rounded-lg text-sm">Enabled</button></div></div></div></div><div className="bg-white dark:bg-slate-800 rounded-xl p-6 shadow-sm border"><h3 className="font-semibold mb-4 flex items-center gap-2"><Shield size={18} /> Integrations</h3><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3"><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><span className="text-sm">Email Marketing</span><button onClick={() => onToast("Email Marketing connected", "success")} className="px-3 py-1 bg-indigo-100 text-indigo-600 rounded text-sm">Connect</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><span className="text-sm">SMS Gateway</span><button onClick={() => onToast("SMS Gateway connected", "success")} className="px-3 py-1 bg-indigo-100 text-indigo-600 rounded text-sm">Connect</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><span className="text-sm">Calendar Sync</span><button onClick={() => onToast("Calendar Sync connected", "success")} className="px-3 py-1 bg-indigo-100 text-indigo-600 rounded text-sm">Connect</button></div><div className="flex justify-between items-center p-3 bg-slate-50 rounded-lg"><span className="text-sm">Slack</span><button onClick={() => { setSlackIntegration(!slackIntegration); onToast(`Slack ${!slackIntegration ? 'connected' : 'disconnected'}`, "success"); }} className={`px-3 py-1 rounded text-sm ${slackIntegration ? 'bg-emerald-100 text-emerald-600' : 'bg-indigo-100 text-indigo-600'}`}>{slackIntegration ? 'Connected' : 'Connect'}</button></div></div></div></div>);
};

// ==================== DEALER LOCATIONS PAGE ====================
const DealerLocationsPage = ({ onToast }) => (<div className="space-y-5"><div className="flex justify-between items-center"><h2 className="text-xl font-semibold">Dealer Locations</h2><button onClick={() => onToast("Add location form opened", "success")} className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ Add Location</button></div><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">{dealerLocations.map(location => (<div key={location.name} className="bg-white dark:bg-slate-800 rounded-xl p-5 border hover:shadow-md"><div className="flex justify-between items-start mb-3"><h3 className="font-semibold text-lg">{location.name}</h3><StatusBadge status="active" /></div><p className="text-sm text-slate-500 flex items-center gap-2"><MapPin size={14} /> {location.address}</p><p className="text-sm text-slate-500 flex items-center gap-2 mt-1"><Clock size={14} /> {location.hours}</p><p className="text-sm text-slate-500 flex items-center gap-2 mt-1"><Phone size={14} /> {location.phone}</p><div className="grid grid-cols-2 gap-3 mt-3 pt-3 border-t"><div className="text-center"><p className="text-xl font-bold text-indigo-600">{location.sales}</p><p className="text-xs text-slate-500">Sales YTD</p></div><div className="text-center"><p className="text-xl font-bold text-emerald-600">{location.service}</p><p className="text-xs text-slate-500">Service ROs</p></div></div><div className="flex items-center justify-between mt-3"><div className="flex gap-0.5">{[...Array(5)].map((_, i) => (<Star key={i} size={14} className={i < location.rating ? "text-yellow-400 fill-yellow-400" : "text-slate-300"} />))}</div><button onClick={() => onToast(`Viewing ${location.name} details`, "info")} className="text-indigo-600 text-sm">Manage</button></div></div>))}</div></div>);

// ==================== PROMOTIONS PAGE ====================
const PromotionsPage = ({ onToast }) => (<div className="space-y-5"><div className="flex justify-between items-center"><h2 className="text-xl font-semibold">Active Promotions</h2><button onClick={() => onToast("New promotion created", "success")} className="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ Create Promotion</button></div><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">{promotions.map(promo => (<div key={promo.id} className="bg-white dark:bg-slate-800 rounded-xl p-5 border hover:shadow-md"><div className="flex justify-between items-start mb-3"><h3 className="font-semibold text-lg">{promo.name}</h3><StatusBadge status={promo.active ? "active" : "inactive"} /></div><p className="text-2xl font-bold text-indigo-600">{promo.discount}</p><p className="text-sm text-slate-500 mt-1">Valid until: {promo.validUntil}</p><p className="text-xs text-slate-500 mt-1">Code: {promo.code}</p><div className="flex justify-between items-center mt-3 pt-3 border-t"><div><p className="text-sm text-slate-500">Redemptions</p><p className="text-xl font-bold">{promo.redemption}</p></div><button onClick={() => onToast(`Editing ${promo.name}`, "info")} className="px-3 py-1 bg-indigo-100 text-indigo-600 rounded text-sm">Edit</button></div></div>))}</div></div>);

// ==================== MAIN APP ====================
const App = () => {
  const [darkMode, setDarkMode] = useState(false);
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const [currentPage, setCurrentPage] = useState("dashboard");
  const [selectedLead, setSelectedLead] = useState(null);
  const [toasts, setToasts] = useState([]);
  const [showNotifications, setShowNotifications] = useState(false);
  const [showAiAssistant, setShowAiAssistant] = useState(false);
  const [notifications, setNotifications] = useState(notificationsData);
  
  useEffect(() => { if (darkMode) document.documentElement.classList.add('dark'); else document.documentElement.classList.remove('dark'); }, [darkMode]);
  const addToast = (message, type = "success") => { const id = Date.now(); setToasts(prev => [...prev, { id, message, type }]); };
  const removeToast = (id) => setToasts(prev => prev.filter(t => t.id !== id));
  const markNotificationRead = (id) => { setNotifications(notifications.map(n => n.id === id ? { ...n, read: true } : n)); };
  
  const navigation = [
    { id: "dashboard", label: "Dashboard", icon: LayoutDashboard, section: "MAIN" },
    { id: "leads", label: "Leads", icon: Users, section: "SALES" },
    { id: "inventory", label: "Inventory", icon: Car, section: "SALES" },
    { id: "service", label: "Service", icon: Wrench, section: "SERVICE" },
    { id: "campaigns", label: "Campaigns", icon: Send, section: "MARKETING" },
    { id: "promotions", label: "Promotions", icon: Gift, section: "MARKETING" },
    { id: "analytics", label: "Analytics", icon: BarChart3, section: "ANALYTICS" },
    { id: "locations", label: "Locations", icon: MapPin, section: "SETTINGS" },
    { id: "settings", label: "Settings", icon: Settings, section: "SETTINGS" },
  ];
  
  const renderPage = () => {
    switch (currentPage) {
      case "dashboard": return <Dashboard onToast={addToast} onSelectLead={setSelectedLead} />;
      case "leads": return <LeadsPage onToast={addToast} onSelectLead={setSelectedLead} />;
      case "inventory": return <InventoryPage onToast={addToast} />;
      case "service": return <ServicePage onToast={addToast} />;
      case "campaigns": return <CampaignsPage onToast={addToast} />;
      case "promotions": return <PromotionsPage onToast={addToast} />;
      case "analytics": return <AnalyticsPage onToast={addToast} />;
      case "locations": return <DealerLocationsPage onToast={addToast} />;
      case "settings": return <SettingsPage onToast={addToast} />;
      default: return <Dashboard onToast={addToast} onSelectLead={setSelectedLead} />;
    }
  };
  
  return (<div className="flex h-screen bg-slate-50 dark:bg-slate-900"><aside className={`${sidebarCollapsed ? 'w-20' : 'w-64'} bg-white dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 transition-all duration-300 flex flex-col`}><div className="p-5 border-b flex items-center justify-between">{!sidebarCollapsed && <div><span className="text-xl font-bold bg-gradient-to-r from-indigo-500 to-purple-500 bg-clip-text text-transparent">AutoDeal CRM</span><p className="text-xs text-slate-500">Ultimate Enterprise v8.0</p></div>}<button onClick={() => setSidebarCollapsed(!sidebarCollapsed)} className="p-1.5 hover:bg-slate-100 rounded-lg"><ChevronLeft size={18} className={sidebarCollapsed ? "rotate-180" : ""} /></button></div><nav className="flex-1 p-3 space-y-6 overflow-y-auto">{["MAIN", "SALES", "SERVICE", "MARKETING", "ANALYTICS", "SETTINGS"].map(section => { const sectionItems = navigation.filter(item => item.section === section); if (sectionItems.length === 0) return null; return (<div key={section}>{!sidebarCollapsed && <p className="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 px-3">{section}</p>}<div className="space-y-1">{sectionItems.map(item => (<button key={item.id} onClick={() => setCurrentPage(item.id)} className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all ${currentPage === item.id ? 'bg-indigo-50 text-indigo-600' : 'text-slate-600 hover:bg-slate-100'}`}><item.icon size={20} />{!sidebarCollapsed && <span className="text-sm font-medium">{item.label}</span>}</button>))}</div></div>); })}</nav></aside><div className="flex-1 flex flex-col overflow-hidden"><header className="bg-white dark:bg-slate-800 border-b px-6 py-3 flex items-center justify-between"><h1 className="text-lg font-semibold">{navigation.find(n => n.id === currentPage)?.label || "Dashboard"}</h1><div className="flex items-center gap-4"><GlobalSearch onSelect={(result) => { if (result.type === "lead") setSelectedLead(result); else addToast(`Selected ${result.make} ${result.model}`, "info"); }} /><button onClick={() => setDarkMode(!darkMode)} className="p-2 hover:bg-slate-100 rounded-lg">{darkMode ? <Sun size={18} /> : <Moon size={18} />}</button><div className="relative"><button onClick={() => { setShowNotifications(!showNotifications); setShowAiAssistant(false); }} className="p-2 hover:bg-slate-100 rounded-lg relative"><Bell size={18} /><span className="absolute top-1 right-1 w-2 h-2 bg-rose-500 rounded-full"></span></button>{showNotifications && <NotificationCenter notifications={notifications} onClose={() => setShowNotifications(false)} onMarkRead={markNotificationRead} />}</div><button onClick={() => { setShowAiAssistant(!showAiAssistant); setShowNotifications(false); }} className="p-2 hover:bg-slate-100 rounded-lg"><Bot size={18} /></button><div className="w-8 h-8 rounded-full bg-gradient-to-r from-indigo-500 to-purple-500 flex items-center justify-center text-white text-sm font-bold">AD</div></div></header><main className="flex-1 overflow-y-auto p-6">{renderPage()}</main></div>{selectedLead && <LeadDrawer lead={selectedLead} onClose={() => setSelectedLead(null)} onAction={(action, lead) => addToast(`${action} action for ${lead.name}`, "success")} />}{showAiAssistant && <AiAssistant onClose={() => setShowAiAssistant(false)} onSendMessage={(msg) => addToast(`AI response sent`, "info")} />}<QuickAddFab onAction={(action) => addToast(`${action} action triggered`, "success")} />{toasts.map(toast => <Toast key={toast.id} message={toast.message} type={toast.type} onClose={() => removeToast(toast.id)} />)}</div>);
};

export default App;
